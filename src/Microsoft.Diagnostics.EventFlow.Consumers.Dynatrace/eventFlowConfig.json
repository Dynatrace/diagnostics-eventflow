    //    //}
    //  ]
    //},
    //{
    //  "type": "PerformanceCounter",
    //  "counters": [
    //    {
    //      "counterCategory": "Process",
    //      "counterName": "% Processor Time"
    //    },
    //    {
    //      "counterCategory": "Process",
    //      "counterName": "Private Bytes"
    //    },
    //    {
    //      "counterCategory": ".NET CLR Memory",
    //      "counterName": "% Time in GC"
    //    },
    //    {
    //      "counterCategory": "Process",
    //      "counterName": "# of Exceps Thrown / sec"
    //    }
